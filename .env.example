# Copy to .env.local and fill in. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Google OAuth (Gmail + Drive Picker)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Vercel Cron — shared secret for /api/cron/gmail
CRON_SECRET=

# AES-256-GCM key (base64, 32 bytes) for encrypting Google tokens at rest.
# Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Google Drive Picker (client-side). These are publicly exposed but not secret.
# Same OAuth client ID as the Gmail flow; the API key is created in
# Google Cloud Console under APIs & Services → Credentials → API key, and
# restricted to the Picker API.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
